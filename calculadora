<html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Calculadora Funcional</title>
    <style>
        /* --- ESTILIZAÇÃO (CSS) --- */
        body {
            font-family: Arial, sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            background-color: #f0f2f5;
            margin: 0;
        }

        .calculadora {
            background-color: #ffffff;
            padding: 20px;
            border-radius: 15px;
            box-shadow: 0px 4px 15px rgba(0, 0, 0, 0.1);
            width: 300px;
        }

        #visor {
            width: 100%;
            height: 60px;
            background-color: #e9ecef;
            border: none;
            border-radius: 8px;
            font-size: 24px;
            text-align: right;
            padding: 0 15px;
            box-sizing: border-box;
            margin-bottom: 20px;
            color: #333;
        }

        .botoes {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 10px;
        }

        /* Aqui usamos o elemento <button> para todas as ações do formulário */
        .btn {
            height: 50px;
            border: none;
            border-radius: 8px;
            font-size: 18px;
            cursor: pointer;
            background-color: #f8f9fa;
            transition: background 0.2s;
        }

        .btn:hover {
            background-color: #e2e6ea;
        }

        .operador {
            background-color: #e9ecef;
            font-weight: bold;
        }

        .limpar {
            background-color: #f8d7da;
            color: #721c24;
        }

        .igual {
            background-color: #d4edda;
            color: #155724;
            grid-column: span 2;
        }
    </style>
</head>
<body>

    <div class="calculadora">
        <input type="text" id="visor" readonly>

        <div class="botoes">
            <button class="btn limpar" onclick="limparVisor()">C</button>
            <button class="btn" onclick="inserir('%')">%</button>
            <button class="btn operador" onclick="inserir('/')">/</button>
            
            <button class="btn" onclick="inserir('7')">7</button>
            <button class="btn" onclick="inserir('8')">8</button>
            <button class="btn" onclick="inserir('9')">9</button>
            <button class="btn operador" onclick="inserir('*')">x</button>
            
            <button class="btn" onclick="inserir('4')">4</button>
            <button class="btn" onclick="inserir('5')">5</button>
            <button class="btn" onclick="inserir('6')">6</button>
            <button class="btn operador" onclick="inserir('-')">-</button>
            
            <button class="btn" onclick="inserir('1')">1</button>
            <button class="btn" onclick="inserir('2')">2</button>
            <button class="btn" onclick="inserir('3')">3</button>
            <button class="btn operador" onclick="inserir('+')">+</button>
            
            <button class="btn zero" onclick="inserir('0')">0</button>
            <button class="btn" onclick="inserir('.')">.</button>
            <button class="btn igual" onclick="calcular()">=</button>
        </div>
    </div>

    <script>
        const visor = document.getElementById('visor');

        // Função para colocar os números/operadores na tela
        function inserir(valor) {
            visor.value += valor;
        }

        // Função para o botão "C" (Limpar)
        function limparVisor() {
            visor.value = '';
        }

        // Função para o botão "=" (Calcular)
        function calcular() {
            try {
                if (visor.value !== '') {
                    // O eval resolve a expressão matemática dentro do texto
                    visor.value = eval(visor.value);
                }
            } catch (error) {
                visor.value = 'Erro';
            }
        }
    </script>
</body>
</html>
